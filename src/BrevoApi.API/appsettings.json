{
  "ConnectionStrings": {
    "DefaultConnection": "Server=NIKO\\SQLEXPRESS;Database=BrevoApiDb;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyMustBeAtLeast32CharactersLong!@#$",
    "Issuer": "BrevoApi",
    "Audience": "BrevoApiClient",
    "AccessTokenExpirationMinutes": "60",
    "RefreshTokenExpirationDays": "7"
  },
  "Brevo": {
    "ApiKey": "YOUR_BREVO_API_KEY_HERE"
  },
  "AppSettings": {
    "FrontendUrl": "https://localhost:3000",
    "SenderName": "BrevoApp",
    "SenderEmail": "noreply@yourdomain.com"
  },
  "AdminSettings": {
    "Email": "admin@brevoapi.com",
    "Password": "Admin@123456!"
  },
  "AllowedOrigins": [
    "https://localhost:3000",
    "https://yourdomain.com"
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SmtpSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "YOUR_EMAIL@gmail.com",
    "Password": "YOUR_APP_PASSWORD",
    "EnableSsl": true,
    "UseStartTls": true,
    "DefaultSenderName": "BrevoApp",
    "DefaultSenderEmail": "noreply@yourdomain.com"
  }
}